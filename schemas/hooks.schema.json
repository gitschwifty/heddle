{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Map_of_Array_of_HookDefinition",
  "type": "object",
  "additionalProperties": {
    "type": "array",
    "items": {
      "$ref": "#/definitions/HookDefinition"
    }
  },
  "definitions": {
    "HookDefinition": {
      "description": "Wire-format hook entry from TOML/JSON before defaults are applied.",
      "type": "object",
      "required": [
        "command"
      ],
      "properties": {
        "async": {
          "default": null,
          "type": [
            "boolean",
            "null"
          ]
        },
        "command": {
          "type": "string"
        },
        "matchers": {
          "anyOf": [
            {
              "$ref": "#/definitions/HookMatchers"
            },
            {
              "type": "null"
            }
          ]
        },
        "mode": {
          "anyOf": [
            {
              "$ref": "#/definitions/HookMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "timeout": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "HookMatchers": {
      "type": "object",
      "properties": {
        "match_args": {
          "type": [
            "string",
            "null"
          ]
        },
        "match_input": {
          "type": [
            "string",
            "null"
          ]
        },
        "match_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool": {
          "description": "Either a single tool name or a list of names.",
          "anyOf": [
            {
              "$ref": "#/definitions/ToolMatch"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "HookMode": {
      "type": "string",
      "enum": [
        "interactive",
        "headless",
        "both"
      ]
    },
    "ToolMatch": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    }
  }
}
